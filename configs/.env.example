# ops-agent 环境变量配置模板
# 复制为 .env 并填入实际值

# ── Coding DevOps ───────────────────────────────────────────
# Token 获取: Coding 控制台 → 个人设置 → 访问令牌 → 新建令牌
# 需要的权限 (scope):
#   project:profile:ro     ← 查看项目
#   project:depot:ro       ← 查看代码仓库
#   project:issue:rw       ← 工作项管理
#   project:ci:rw          ← 构建计划管理 / 触发构建 (对应 open_ci_manager)
#   cd:pipeline:ro         ← 查看 CD 部署流程 (可选)
CODING_TOKEN=ce33c12590f8636a097e4673792639963bcf8a25

# ── TKE ─────────────────────────────────────────────────────
TKE_SECRET_ID=
TKE_SECRET_KEY=
TKE_REGION=ap-guangzhou

# ── Jenkins ─────────────────────────────────────────────────
JENKINS_URL=
JENKINS_USER=
JENKINS_TOKEN=

# ── GitLab ──────────────────────────────────────────────────
GITLAB_URL=
GITLAB_TOKEN=
